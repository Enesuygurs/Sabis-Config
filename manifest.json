{
    "manifest_version": 3,
    "name": "SAÜ Config",
    "version": "1.0",
    "description": "SAÜ Config by Enes Uygur",
    "permissions": ["activeTab", "scripting", "tabs", "storage"],
    "background": {
    "service_worker": "background.js"
  },
    "content_scripts": [
      {
        "matches": ["*://*.sakarya.edu.tr/*"],
        "js": ["content.js"]
      }
    ],
    "host_permissions": [
    "https://*.sakarya.edu.tr/*",
    "http://*.sakarya.edu.tr/*"
  ],
  "icons": {
        "16": "images/icon16.png",
        "48": "images/icon48.png"
      },
    "action": {
      "default_popup": "popup.html",
      "default_icon": {
        "16": "images/icon16.png",
        "48": "images/icon48.png"
      }
    }
  }
  